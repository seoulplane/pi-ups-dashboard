# Optional updater configuration file.
# Copy to: /etc/default/pi-ups-dashboard-updater

# Repository in owner/name format
# GITHUB_REPO=seoulplane/pi-ups-dashboard

# Pin to one exact release tag (takes priority over RELEASE_TAG_PATTERN)
# PINNED_TAG=v1.2.3

# Restrict allowed tags using bash regex.
# Stable-only semantic versions:
# RELEASE_TAG_PATTERN='^v[0-9]+\.[0-9]+\.[0-9]+$'
# Allow release candidates too:
# RELEASE_TAG_PATTERN='^v[0-9]+\.[0-9]+\.[0-9]+(-rc\.[0-9]+)?$'

# Optional service settings
# SERVICE_NAME=pi-ups-dashboard.service
# HEALTH_URL=http://127.0.0.1:8080/api/dashboard
# HEALTH_RETRIES=12
# HEALTH_DELAY_SECONDS=2
